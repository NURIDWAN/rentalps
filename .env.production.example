# Public HTTPS domain untuk overlay Caddy.
# A record domain ini harus mengarah ke IP VPS sebelum menjalankan Caddy.
API_DOMAIN=api.domainanda.com

# Bind port backend langsung di host. Default aman: hanya bisa diakses dari VPS.
APP_BIND=127.0.0.1
APP_PORT=8080

# App runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
TLS_ENABLED=false
TLS_MIN_VERSION=TLSv1.2

# PostgreSQL container
PGHOST=postgres
PGPORT=5432
PGDATABASE=ps_rental
PGUSER=ps_rental
PGPASSWORD=ganti_dengan_password_postgres_kuat
PGSSLMODE=disable
PG_POOL_MAX=10

# Redis container
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ganti_dengan_password_redis_kuat
REDIS_DB=0

# Auth
JWT_SECRET=ganti_dengan_output_openssl_rand_hex_32
JWT_EXPIRES_IN=8h
