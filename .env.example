# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=8443
HOST=0.0.0.0

# ── HTTPS / TLS (Req 12.4: TLS 1.2+) ────────────────────
# Set TLS_ENABLED=true untuk mengaktifkan transport HTTPS.
# Untuk pengembangan lokal, hasilkan sertifikat self-signed (lihat README).
TLS_ENABLED=false
TLS_KEY_PATH=certs/server.key
TLS_CERT_PATH=certs/server.crt
# Versi TLS minimum yang diizinkan. Jangan turunkan di bawah TLSv1.2.
TLS_MIN_VERSION=TLSv1.2

# ── PostgreSQL ──────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=ps_rental
PGUSER=ps_rental
PGPASSWORD=change_me
PGSSLMODE=disable
PG_POOL_MAX=10

# ── Redis (timer job/cache) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth (JWT) ──────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h
