{
  "name": "ps-rental-control-backend",
  "version": "0.1.0",
  "description": "Backend Server untuk PS Rental Control App (MVP / Fase 1) - Node.js/TypeScript + Express, Redis, PostgreSQL",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.vercel.json --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint \"{src,api}/**/*.ts\"",
    "lint:fix": "eslint \"{src,api}/**/*.ts\" --fix",
    "test": "npm run typecheck"
  },
  "keywords": [
    "ps-rental",
    "express",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/express": "4.17.21",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "eslint": "9.17.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.19.1"
  }
}
